{
	"name": "auto-pr",
	"version": "0.1.0",
	"description": "Auto-create PRs from conventional commits on ai/* branches",
	"keywords": [
		"auto-pr",
		"conventional-commits",
		"github",
		"github-actions",
		"ollama",
		"pr-template",
		"ai-assisted-development",
		"pull-request"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/knirski/auto-pr.git"
	},
	"homepage": "https://github.com/knirski/auto-pr#readme",
	"bugs": {
		"url": "https://github.com/knirski/auto-pr/issues"
	},
	"type": "module",
	"bin": {
		"auto-pr-get-commits": "./bin/auto-pr-get-commits.mjs",
		"auto-pr-generate-content": "./bin/generate-pr-content.mjs",
		"auto-pr-create-or-update-pr": "./bin/create-or-update-pr.mjs",
		"auto-pr-fill-pr-template": "./bin/fill-pr-template.mjs",
		"auto-pr-init": "./bin/init.mjs"
	},
	"scripts": {
		"test": "vitest run --coverage --typecheck",
		"test:unit": "vitest run --coverage=false --typecheck",
		"test:watch": "vitest",
		"check": "bash scripts/check-nix-hash.sh && npm run check:code && npm run check:docs && npm run lint:workflows && npm run lint:scripts",
		"check:code": "npm audit --audit-level=high && npm run test && npm run lint && npm run knip && npm run typecheck",
		"check:with-links": "npm run check && npm run check:just-links",
		"check:docs": "scripts/nix-run-if-missing.sh rumdl check . && scripts/nix-run-if-missing.sh typos",
		"check:just-links": "scripts/nix-run-if-missing.sh lychee --timeout 30 --max-retries 10 --retry-wait-time 2 --no-progress .",
		"lint": "biome check .",
		"lint:fix": "biome check . --write --unsafe",
		"lint:scripts": "find scripts -name '*.sh' -print0 | xargs -0 -r scripts/nix-run-if-missing.sh shellcheck",
		"lint:workflows": "scripts/nix-run-if-missing.sh actionlint",
		"format": "biome format --write .",
		"knip": "knip",
		"typecheck": "tsgo --noEmit",
		"prepare": "lefthook install",
		"get-commits": "tsx scripts/auto-pr-get-commits.ts",
		"generate-content": "tsx scripts/generate-pr-content.ts",
		"create-or-update-pr": "tsx scripts/create-or-update-pr.ts",
		"fill-pr-template": "tsx scripts/fill-pr-template.ts",
		"build": "echo 'No build step; scripts run via tsx'",
		"update-nix-hash": "node scripts/update-nix-hash.mjs"
	},
	"dependencies": {
		"@effect/platform-node": "4.0.0-beta.31",
		"@effect/platform-node-shared": "4.0.0-beta.31",
		"conventional-commits-parser": "^6.3.0",
		"effect": "4.0.0-beta.31",
		"remark": "^15.0.1",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@cyclonedx/cyclonedx-npm": "^4.2.1",
		"@biomejs/biome": "^2.4.6",
		"@effect/vitest": "4.0.0-beta.31",
		"@types/mdast": "^4.0.4",
		"@types/node": "^24.0.0",
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@typescript/native-preview": "^7.0.0-dev",
		"@vitest/coverage-v8": "^4.0.18",
		"knip": "^5.86.0",
		"lefthook": "^2.1.4",
		"lint-staged": "^16.3.2",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{ts,tsx,mjs}": [
			"npx biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"commitlint": {
		"extends": ["@commitlint/config-conventional"]
	},
	"engines": {
		"node": ">=24.0.0",
		"typescript": ">=5.0.0"
	},
	"packageManager": "npm@10.9.0"
}
